{
    "name": "dejwcake/admin-listing",
    "description": "Query-building helper for listing of Eloquent models",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "listing",
        "eloquent",
        "datatable",
        "admin",
        "cms",
        "laravel"
    ],
    "authors": [
        {
            "name": "David Běhal",
            "email": "david.behal@dejw.sk",
            "homepage": "https://www.dejw.sk",
            "role": "Developer"
        },
        {
            "name": "Pavol Perdík",
            "email": "pavol.perdik@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        },
        {
            "name": "Richard Dominik",
            "email": "richard.dominik@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "dejwcake/craftable-translatable": "^2.0",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.1",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^13.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Brackets\\AdminListing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brackets\\AdminListing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev",
            "dev-v2-dev": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Brackets\\AdminListing\\AdminListingServiceProvider"
            ]
        }
    }
}
